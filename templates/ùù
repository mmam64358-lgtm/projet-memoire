<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0"> 
    
    <!-- Redirect to Flask backend if opened with Live Server -->
    <script>
        if (window.location.port === "5501") {
            window.location.replace("http://127.0.0.1:5500/");
        }
        if (window.location.port !== "5500" && window.location.protocol === "http:") {
            window.location.replace("http://127.0.0.1:5500/report");
        }
        if (window.location.protocol === "file:") {
            window.location.replace("http://127.0.0.1:5500/report");
        }
    </script>
      
    <title>Report an Emergency</title>
    
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin=""/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">
    
    <style>
        /* Ambient background glow matching the design */
        body { 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            min-height: 100vh; 
            padding: 20px; 
            overflow-y: auto;
            background-color: #0b0c10;
            background-image: 
                radial-gradient(circle at 15% 35%, rgba(255, 110, 50, 0.12) 0%, transparent 40%),
                radial-gradient(circle at 85% 65%, rgba(66, 133, 244, 0.08) 0%, transparent 40%);
        }
        .client-container { 
            max-width: 450px; /* Reduced width for a sleeker login card look */
            width: 100%; 
            padding: 35px 30px; 
            border-radius: 16px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            background: rgba(20, 20, 22, 0.65);
            /* Stronger glassmorphism effect */
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.06);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.05);
            margin: auto;
        }
        h2 { 
            color: var(--text-primary); 
            text-align: center; 
            font-weight: 700;
            margin-bottom: 5px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        p.subtitle {
            text-align: center;
            color: var(--text-secondary);
            font-size: 0.9rem;
            margin-bottom: 10px;
        }
        
        .client-form label { 
            display: block; 
            margin-top: 18px; 
            margin-bottom: 8px;
            color: var(--text-secondary);
            font-weight: 500;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .client-form input, .client-form select, .client-form textarea {
            width: 100%;
            background: var(--card-bg);
            border: 1px solid rgba(255, 255, 255, 0.08);
            color: var(--text-primary);
            padding: 12px 16px;
            border-radius: var(--radius-sm);
            font-family: inherit;
            font-size: 0.95rem;
            box-sizing: border-box;
            transition: all 0.3s ease;
            resize: vertical;
        }
        
        .client-form input:focus, .client-form select:focus, .client-form textarea:focus {
            border-color: var(--electric-blue);
            box-shadow: 0 0 0 2px rgba(255, 87, 34, 0.2);
            outline: none;
        }
        
        .location-btn { 
            background: rgba(255, 87, 34, 0.05); 
            color: var(--electric-blue); 
            border: 1px solid var(--electric-blue);
            cursor: pointer; 
            padding: 12px; 
            font-size: 0.95rem;
            font-weight: 600;
            border-radius: var(--radius-sm);
            width: 100%;
            transition: all 0.3s ease;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
        }
        .location-btn:hover {
            background: rgba(255, 87, 34, 0.2);
            box-shadow: 0 0 15px rgba(255, 87, 34, 0.2);
        }
        
        .submit-btn { 
            background: var(--crimson); 
            color: #fff; 
            border: none; 
            cursor: pointer; 
            font-size: 1.05rem; 
            font-weight: 700; 
            margin-top: 25px; 
            padding: 16px; 
            width: 100%;
            border-radius: var(--radius-sm);
            transition: all 0.3s ease;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
        }
        .submit-btn:hover {
            background: #dc2626;
            box-shadow: 0 0 10px rgba(239, 68, 68, 0.3);
            transform: translateY(-2px);
        }
        .submit-btn:disabled { 
            background: rgba(239, 68, 68, 0.15); 
            color: rgba(255,255,255,0.5);
            cursor: not-allowed; 
            transform: none;
            box-shadow: none;
        }
        
        .status { 
            margin-top: 10px; 
            text-align: center; 
            font-size: 0.85rem; 
            color: var(--text-sidebar); 
        }

        #resStatus {
            margin-top: 15px; 
            text-align: center; 
            font-size: 0.95rem; 
            font-weight: bold;
        }
        
        #map { 
            height: 250px; 
            margin-top: 10px; 
            border-radius: var(--radius-sm); 
            border: 1px solid rgba(255, 255, 255, 0.08);
            width: 100%;
            z-index: 1;
        }
        
        .leaflet-container {
            background: var(--midnight-blue) !important;
            font-family: inherit;
        }
    </style>
</head>
<body>
    <div class="client-container glass-panel">
        {% if not session.get('user') %}
            <!-- واجهة الدخول السريعة: بدون باسوورد خاطرش حالة طوارئ -->
            <div style="margin-bottom: 25px;">
                <h2 style="text-align: left; font-size: 1.8rem; margin: 0; color: #fff; justify-content: flex-start; font-weight: 600;">Emergency Portal</h2>
                <p style="color: #aaa; font-size: 0.95rem; margin-top: 8px; text-align: left; line-height: 1.4;">Every second counts. Enter your email to instantly access the reporting map.</p>
            </div>
            
            <form action="/login/local" method="POST">
                <div style="margin-bottom: 15px;">
                    <label style="display:block; color: #ccc; margin-bottom: 8px; font-size: 0.85rem; font-weight: 500;">Email address</label>
                    <input type="email" name="email" required placeholder="you@domain.com" style="width: 100%; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.06); padding: 14px 15px; border-radius: 10px; color: #fff; transition: 0.3s; outline: none;" onfocus="this.style.borderColor='#ff7e5f';" onblur="this.style.borderColor='rgba(255,255,255,0.06)';">
                </div>

                <div style="text-align: left; margin-bottom: 20px;">
                    <span style="color: #ff7e5f; font-size: 0.8rem;"><i class="fa-solid fa-lock" style="margin-right: 5px;"></i> No password required for identity verification.</span>
                </div>

                <button type="submit" style="width: 100%; padding: 14px; border-radius: 10px; background: linear-gradient(90deg, #ff416c, #ff4b2b); color: white; font-weight: 600; border: none; font-size: 1.05rem; cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 0 15px rgba(255, 65, 108, 0.4)'; this.style.transform='translateY(-1px)';" onmouseout="this.style.boxShadow='none'; this.style.transform='none';">
                    Proceed to Map <i class="fa-solid fa-arrow-right" style="margin-left: 5px;"></i>
                </button>
            </form>

            <!-- تم إخفاء زر Google Sign In، فقط الدخول المحلي ظاهر -->
        {% endif %}

        <!-- المكونات هادو كامل يتخباو (مايظهروش) حتى ينجح تسجيل الدخول -->
        <div {% if not session.get('user') %}style="display: none;"{% endif %}>
            <h2 style="margin-bottom: 20px;"><i class="fa-solid fa-triangle-exclamation" style="color: var(--crimson);"></i> Report Emergency</h2>
            
            {% if session.get('user') %}
                <div style="background: rgba(66, 133, 244, 0.1); border: 1px solid var(--electric-blue); border-radius: var(--radius-sm); padding: 12px; margin-bottom: 15px; display: flex; justify-content: space-between; align-items: center;">
                    <div style="display: flex; align-items: center; gap: 10px;">
                        <img src="{{ session['user']['picture'] }}" alt="Profile" style="width: 32px; height: 32px; border-radius: 50%;">
                        <div>
                            <p style="color: var(--text-primary); font-size: 0.9rem; margin: 0; font-weight: 600;">{{ session['user']['name'] }}</p>
                            <p style="color: var(--text-secondary); font-size: 0.8rem; margin: 0;">{{ session['user']['email'] }}</p>
                        </div>
                    </div>
                    <a href="/logout" style="color: var(--crimson); text-decoration: none; font-size: 0.85rem; font-weight: bold;"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
                </div>
            {% endif %}
            
            <form id="reportForm" class="client-form">
                <label><i class="fa-regular fa-comment-dots" style="margin-right:5px"></i> Emergency Description</label>
            <textarea id="desc" rows="3" required placeholder="Describe the situation clearly (e.g., 'Fire in the factory...')..."></textarea>

            <label><i class="fa-solid fa-gauge-high" style="margin-right:5px"></i> Severity Level</label>
            <select id="severity">
                <option value="medium">🟠 Medium - Controlled hazard</option>
                <option value="high">🔴 High - Approaching danger</option>
                <option value="critical">🚨 Critical - Immediate threat</option>
            </select>

            <label><i class="fa-solid fa-map-location-dot" style="margin-right:5px"></i> Precise Location</label>
            <div id="map"></div>
            <button type="button" class="location-btn" id="locBtn" style="margin-top: 15px;">
                <i class="fa-solid fa-crosshairs"></i> Detect My GPS Location
            </button>
            <div class="status" id="locStatus">Tap on the map or use GPS...</div>
            
            <input type="hidden" id="lat">
            <input type="hidden" id="lng">
            
            {% if session.get('user') %}
            <input type="hidden" id="reporterName" value="{{ session['user']['name'] }}">
            <input type="hidden" id="reporterEmail" value="{{ session['user']['email'] }}">
            {% endif %}

            <button type="submit" class="submit-btn" id="submitBtn" disabled>
                <i class="fa-solid fa-paper-plane"></i> SUBMIT ALERT
            </button>
            
            <div id="resStatus"></div>
        </form>
        </div><!-- نهاية الإخفاء -->
    </div>

    <!-- Script imports -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
    <script>
        const locBtn = document.getElementById("locBtn");
        const locStatus = document.getElementById("locStatus");
        const latInput = document.getElementById("lat");
        const lngInput = document.getElementById("lng");
        const submitBtn = document.getElementById("submitBtn");
        const reportForm = document.getElementById("reportForm");
        const resStatus = document.getElementById("resStatus");

        // Initialize Map centered on Chlef
        const map = L.map("map").setView([36.166, 1.333], 12);
        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {   
            maxZoom: 19,
            attribution: "© OpenStreetMap"
        }).addTo(map);

        let marker;

        // Function to update location visually and internally
        function setLocation(lat, lng) {
            latInput.value = lat;
            lngInput.value = lng;
            locStatus.textContent = `Location selected: ${lat.toFixed(4)}, ${lng.toFixed(4)}`;
            submitBtn.disabled = false;

            if (marker) {
                marker.setLatLng([lat, lng]);
            } else {
                marker = L.marker([lat, lng]).addTo(map);
            }
            map.setView([lat, lng], 14);
        }

        // Map Click Event
        map.on("click", function(e) {
            setLocation(e.latlng.lat, e.latlng.lng);
        });

        // GPS Button Event
        locBtn.addEventListener("click", () => {
            locStatus.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Detecting GPS Location...';
            if (!navigator.geolocation) {
                fallbackLocation();
                return;
            }
            navigator.geolocation.getCurrentPosition(
                (pos) => {
                    setLocation(pos.coords.latitude, pos.coords.longitude);   
                },
                (err) => {
                    fallbackLocation();
                },
                { enableHighAccuracy: true }
            );
        });

        function fallbackLocation() {
            setLocation(36.166, 1.333);
            locStatus.textContent = "Location access denied. Using default Chlef center.";
        }

        reportForm.addEventListener("submit", async (e) => {
            e.preventDefault();
            resStatus.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Sending alert...';

            const payload = {
                title: "Citizen Report",
                description: document.getElementById("desc").value,
                severity: document.getElementById("severity").value,
                lat: parseFloat(latInput.value),
                lng: parseFloat(lngInput.value),
            };

            const reporterNameEl = document.getElementById("reporterName");
            const reporterEmailEl = document.getElementById("reporterEmail");
            if (reporterNameEl && reporterEmailEl) {
                payload.reporter_name = reporterNameEl.value;
                payload.reporter_email = reporterEmailEl.value;
            }

            try {
                const res = await fetch("/api/alerts", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload)
                });
                if (res.ok) {
                    resStatus.style.color = "var(--electric-blue)"; // Neon blue for success
                    resStatus.innerHTML = '<i class="fa-solid fa-circle-check"></i> Report sent successfully! Control center notified.';
                    reportForm.reset();
                    submitBtn.disabled = true;
                    locStatus.textContent = "Tap on the map or use GPS to set location...";
                    if(marker) { map.removeLayer(marker); marker = null; }    
                } else {
                    resStatus.style.color = "var(--crimson)"; // Red for error
                    resStatus.innerHTML = '<i class="fa-solid fa-triangle-exclamation"></i> Error sending. Please try again.';
                }
            } catch (err) {
                resStatus.style.color = "var(--crimson)";
                resStatus.innerHTML = '<i class="fa-solid fa-wifi"></i> Network error. Please try again.';   
            }
        });
    </script>
</body>
</html>